{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "devPath": "../launcher",
    "distDir": "../launcher"
  },
  "package": {
    "productName": "Imperium Deck Client",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "targets": ["appimage"],
      "identifier": "com.snyderconsulting.imperiumdeckclient",
      "icon": ["icons/icon.png"]
    },
    "windows": [
      {
        "title": "Imperium Deck Client",
        "width": 1280,
        "height": 820,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
